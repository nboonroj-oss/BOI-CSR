rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: imageOverrides
    // Document ID: projectId
    // Fields:
    //   - projectId: string (required)
    //   - imageUrls: list (required, list of strings)
    //   - updatedAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "n.boonroj@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isValidImageOverride(data) {
      return data.keys().hasAll(['projectId', 'imageUrls', 'updatedAt']) &&
             data.keys().hasOnly(['projectId', 'imageUrls', 'updatedAt']) &&
             data.projectId is string &&
             data.imageUrls is list &&
             data.imageUrls.size() > 0 &&
             data.imageUrls.size() <= 5 &&
             data.updatedAt is timestamp;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'projects', 'createdAt']) &&
             data.keys().hasOnly(['name', 'email', 'projects', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.email is string && data.email.matches("^[^@]+@[^@]+\\.[^@]+$") &&
             data.projects is list && data.projects.size() > 0 && data.projects.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /imageOverrides/{projectId} {
      // Allow anyone to read the image overrides
      allow read: if true;
      
      // Only admins can create or update image overrides
      allow create, update: if isAdmin() && isValidImageOverride(request.resource.data);
      
      // Only admins can delete
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      // Only admins can read the inquiries
      allow read: if isAdmin();
      
      // Anyone can create an inquiry
      allow create: if isValidInquiry(request.resource.data);
      
      // No updates or deletes for inquiries (for audit trail)
      allow update, delete: if isAdmin();
    }
  }
}
